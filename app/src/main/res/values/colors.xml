<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
    <color name="blue">#116EB8</color>
    <color name="yellow">#F8BB07</color>
    <color name="cream">#E4DEC782</color>
    <color name="green">#33B338</color>
    <color name="red">#ED1B0C</color>

    <style name="CalendarDateText" parent="@android:style/TextAppearance.Small">
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="CalendarWeekText" parent="@android:style/TextAppearance.Small">
        <item name="android:textColor">@color/blue</item>
    </style>

    <style name="CalendarHeaderText" parent="@android:style/TextAppearance.Large">
        <item name="android:textColor">@color/blue</item>
    </style>

    <style name="ProfileLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/blue</item>
        <item name="android:paddingTop">8dp</item>
    </style>

    <style name="ProfileInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@android:color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:padding">10dp</item>

    </style>



</resources>