<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="5dp"
    android:background="@color/white">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:elevation="8dp"
        app:cardCornerRadius="12dp"
        android:padding="12dp"
        android:backgroundTint="@color/white"
        tools:ignore="MissingConstraints">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="10dp"
            android:paddingBottom="10dp">

            <!-- Tick Button (Check Icon) -->
            <ImageView
                android:id="@+id/button_select_appointment"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginTop="10dp"
                android:layout_marginRight="10dp"
                android:src="@drawable/ic_check_circle"
                android:contentDescription="Select Appointment"
                app:tint="@android:color/holo_green_dark" />

            <LinearLayout
                android:layout_below="@+id/button_select_appointment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <!-- Doctor Name -->
                <TextView
                    android:id="@+id/text_doctor_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Doctor: John Doe"
                    android:layout_marginTop="5dp"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/blue" />

                <!-- Patient Name -->
                <TextView
                    android:id="@+id/text_patient_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Patient: John Doe"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#000000" />




                <!-- Date and Time -->
                <TextView
                    android:id="@+id/text_appointment_datetime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date: 2025-04-30 | Time: 10:30 AM"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="5dp"/>

                <!-- Reason -->
                <TextView
                    android:id="@+id/text_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reason: Regular Checkup"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="5dp"/>

                <!-- Contact -->
                <TextView
                    android:id="@+id/text_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email: johndoe@example.com | Phone: 123-456-7890"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="5dp"/>

                <!-- Next of Kin -->
                <TextView
                    android:id="@+id/text_kin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Next of Kin: Jane Doe | Phone: 098-765-4321"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_marginTop="5dp"/>

                <!-- Status -->
                <TextView
                    android:id="@+id/text_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: Pending"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_orange_dark"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>


</LinearLayout>