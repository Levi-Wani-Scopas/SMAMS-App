<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/selected_date_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calender"
        android:textSize="15sp"
        android:layout_gravity="center"
        android:textColor="@color/blue"
        android:textStyle="bold"/>

    <CalendarView
        android:id="@+id/calendar_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:dateTextAppearance="@style/CalendarDateText"
        android:weekDayTextAppearance="@style/CalendarWeekText"

        />







    <!-- Mini Notepad -->
    <TextView
        android:id="@+id/notepad_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Take a note!"
        android:textSize="16sp"
        android:textColor="@color/blue"
        android:layout_marginTop="5dp"/>

    <EditText
        android:id="@+id/notepad_input"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:hint="Your saved note will appear here..."
        android:textColor="@color/black"
        android:textColorHint="#AB6592B6"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:gravity="top"/>

    <Button
        android:id="@+id/save_notepad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Note"
        android:layout_marginTop="3dp"
        android:backgroundTint="@color/blue"
        android:textColor="@color/white"/>


</LinearLayout>
