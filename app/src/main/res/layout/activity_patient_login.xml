<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PatientLoginActivity"
    android:orientation="vertical"
    android:background="@color/white"
    android:gravity="center"
    android:padding="20dp">

    <ImageView
        android:id="@+id/PatientBack"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/arrow_back"
        android:contentDescription="return to previous"
        android:layout_gravity="start|top" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_centerInParent="true"/>

    <!-- App Logo -->
    <ImageView
        android:id="@+id/PatientLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/patient"
        android:layout_gravity="center_horizontal"
        android:contentDescription="App Logo" />

    <!-- Welcome Text -->
    <TextView
        android:id="@+id/PatientWelcomeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello! 😊"
        android:textSize="22sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:padding="5dp" />

    <TextView
        android:id="@+id/PatientSubText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please provide valid credentials to continue"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_marginBottom="10dp"
        android:layout_gravity="center_horizontal" />

    <!-- White Card Container for Login -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:background="@drawable/login_rounded_shape"
        android:padding="20dp"
        android:elevation="10dp">

        <TextView
            android:id="@+id/PatientTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Patient Login"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:layout_editor_absoluteY="21dp"
            tools:ignore="MissingConstraints" />

        <!-- Username Field -->
        <EditText
            android:id="@+id/PatientUsername"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Email"
            android:paddingLeft="10dp"
            android:textColor="@color/black"
            android:textColorHint="#999999"
            android:paddingRight="10dp"
            android:drawableEnd="@drawable/ic_user"
            android:layout_marginTop="20dp"
            android:background="@color/white"
            app:layout_constraintTop_toBottomOf="@+id/PatientTxt"/>

        <!-- Password Field -->
        <EditText
            android:id="@+id/PatientPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:layout_marginTop="10dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:textColorHint="#999999"
            android:textColor="@color/black"
            android:drawableEnd="@drawable/ic_lock"
            android:background="@color/white"
            app:layout_constraintTop_toBottomOf="@id/PatientUsername"/>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/PatientForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:layout_gravity="end"
            android:padding="10dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/PatientLoginButton"
            app:layout_constraintEnd_toEndOf="@id/PatientLoginButton"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/PatientLoginButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Login"
            android:backgroundTint="@color/black"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/PatientPassword"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Signup Link -->
    <TextView
        android:id="@+id/PatientSignup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Signup"
        android:textSize="17sp"
        android:textColor="#2196F3"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp" />

    <!-- Social Login Icons -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visit us on"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="55dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="10dp">

        <ImageView
            android:id="@+id/PatientFacebookLogo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/facebook"
            android:contentDescription="Facebook Login" />

        <ImageView
            android:id="@+id/PatientGoogleLogo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/google"
            android:contentDescription="Google Login"
            android:layout_marginStart="20dp" />

        <ImageView
            android:id="@+id/PatientxLogo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/x"
            android:contentDescription="X Login"
            android:layout_marginStart="20dp" />
    </LinearLayout>





</LinearLayout>
