<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="10dp"
    tools:context=".DoctorDashboardFragment"
    android:background="@color/white">


    <TextView
        android:id="@+id/welcome_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Doctor"
        android:textSize="25sp"
        android:paddingLeft="20dp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:textColor="#646363" />



    <!-- CardView Below Toolbar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mypatient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="5dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:cardCornerRadius="12dp"
        tools:ignore="MissingConstraints"
        app:layout_constraintTop_toBottomOf="@id/welcome_text">

        <!-- CardView Content 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="horizontal">

            <!-- ImageView -->
            <ImageView
                android:id="@+id/mypatientImg"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_marginEnd="15dp"
                android:src="@drawable/mypatient2" />

            <!-- TextView -->
            <TextView
                android:id="@+id/mypatientcard_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="My Patients"
                android:textColor="@color/black"
                android:textSize="17sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <!-- CardView Below Toolbar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/myappointment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginTop="20dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:cardCornerRadius="12dp"
        tools:ignore="MissingConstraints"
        app:layout_constraintTop_toBottomOf="@id/mypatient">

        <!-- CardView Content 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="horizontal">

            <!-- ImageView -->
            <ImageView
                android:id="@+id/myappointmentImg"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_marginEnd="15dp"
                android:src="@drawable/myappointment5" />

            <!-- TextView -->
            <TextView
                android:id="@+id/myappointmentcard_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="My Appointments"
                android:textColor="@color/black"
                android:textSize="17sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>











</androidx.constraintlayout.widget.ConstraintLayout>
