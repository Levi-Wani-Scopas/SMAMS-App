<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/auth"
    android:gravity="center"
    android:background="@color/white">

    <!-- Authorization Header -->
    <TextView
        android:id="@+id/tvAuthorization"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Authorization"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Authentication Icon -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/heart"
        android:layout_marginBottom="20dp"
        android:contentDescription="Security Icon"/>

    <!-- Role Selection Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll"
        android:layout_width="match_parent"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:layout_height="375dp"
        android:orientation="vertical"

        android:padding="30dp"
        android:background="#EBE8D6"
        android:elevation="10dp">

        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Please provide valid credentials to continue"
            android:textColor="@color/black"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Patients Image -->
        <ImageView
            android:id="@+id/ImagePatients"
            android:layout_width="120dp"
            android:layout_height="110dp"
            android:text="Patients"
            android:src="@drawable/patient"
            android:padding="10dp"
            app:layout_constraintTop_toBottomOf="@+id/text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ImageDoctors"
            app:layout_constraintHorizontal_chainStyle="spread_inside"/>

        <TextView
            android:id="@+id/Txtpatient"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="20sp"
            app:layout_constraintTop_toBottomOf="@id/ImagePatients"
            app:layout_constraintStart_toStartOf="@id/ImagePatients"
            app:layout_constraintEnd_toEndOf="@id/ImagePatients"
            android:gravity="center" />



        <!-- Doctors Image -->
        <ImageView
            android:id="@+id/ImageDoctors"
            android:layout_width="120dp"
            android:layout_height="110dp"
            android:padding="10dp"
            android:src="@drawable/doctor"
            android:text="Doctors"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toEndOf="@id/ImagePatients"
            app:layout_constraintTop_toBottomOf="@id/text" />

        <TextView
            android:id="@+id/TxtDoctor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Doctor"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="20sp"
            app:layout_constraintTop_toBottomOf="@id/ImageDoctors"
            app:layout_constraintStart_toStartOf="@id/ImageDoctors"
            app:layout_constraintEnd_toEndOf="@id/ImageDoctors"
            android:gravity="center"/>


        <!-- Admin Image -->
        <ImageView
            android:id="@+id/ImageAdmin"
            android:layout_width="120dp"
            android:layout_height="110dp"
            android:layout_marginTop="30dp"
            android:padding="10dp"
            android:src="@drawable/admin"
            android:text="Doctors"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ImageDoctors" />

        <TextView
            android:id="@+id/TxtAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Admin"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ImageAdmin" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="For more information,"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="italic"
        android:text="Reach us on info@smamonitoroingsystem"
        android:textSize="14sp"
        android:padding="5dp"
        android:textColor="#0289F4"
        android:clickable="true"
        android:focusable="true"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All rights reserved."
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:layout_marginTop="20dp"/>



</LinearLayout>
