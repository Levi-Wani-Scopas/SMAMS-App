<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="20dp">

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/profile_image"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_profile_placeholder"
            android:scaleType="centerCrop"
            android:background="@color/white"
            android:contentDescription="Profile Image"
            android:layout_gravity="center"
            android:padding="4dp"/>

        <!-- Change Profile Image Button -->
        <Button
            android:id="@+id/change_profile_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Profile Picture"
            android:visibility="gone"/>

        <!-- Name -->
        <TextView
            android:text="Name"
            style="@style/ProfileLabel"/>

        <EditText
            android:id="@+id/edit_name"
            style="@style/ProfileInput"
            android:hint="Enter Name"
            android:textColorHint="#A2898989"/>

        <!-- Email (Non-editable) -->
        <TextView
            android:text="Email"
            style="@style/ProfileLabel"/>

        <EditText
            android:id="@+id/edit_email"
            style="@style/ProfileInput"
            android:hint="Email"
            android:enabled="false"
            android:textColorHint="#A2898989"/>

        <!-- Date of Birth -->
        <TextView
            android:text="Date of Birth"
            style="@style/ProfileLabel"/>

        <Button
            android:id="@+id/btn_dob"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Date of Birth"
            android:backgroundTint="#A9DCDADA"
            android:textColor="@color/black"/>

        <!-- Phone Number -->
        <TextView
            android:text="Phone Number"
            style="@style/ProfileLabel"/>

        <EditText
            android:id="@+id/edit_phone"
            style="@style/ProfileInput"
            android:hint="Enter Phone Number"
            android:textColorHint="#A2898989"/>

        <!-- Blood Group -->
        <TextView
            android:text="Blood Group"
            style="@style/ProfileLabel"/>

        <EditText
            android:id="@+id/edit_blood_group"
            style="@style/ProfileInput"
            android:hint="Enter Blood Group"
            android:textColorHint="#A2898989"/>

        <!-- Gender Selection -->
        <TextView
            android:text="Gender"
            style="@style/ProfileLabel"/>

        <RadioGroup
            android:id="@+id/gender_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radio_male"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Male"

                android:textColor="@color/black"/>

            <RadioButton
                android:id="@+id/radio_female"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female"
                android:textColor="@color/black"/>

        </RadioGroup>

        <!-- Next of Kin Name -->
        <TextView
            android:text="Next of Kin Name"
            style="@style/ProfileLabel"/>

        <EditText
            android:id="@+id/edit_kin_name"
            style="@style/ProfileInput"
            android:hint="Enter Next of Kin Name"
            android:textColorHint="#A2898989"/>

        <!-- Next of Kin Phone Number -->
        <TextView
            android:text="Next of Kin Phone Number"
            style="@style/ProfileLabel"/>

        <EditText
            android:id="@+id/edit_kin_phone"
            style="@style/ProfileInput"
            android:hint="Enter Next of Kin Phone Number"
            android:textColorHint="#A2898989"/>

        <!-- Edit Profile Button -->
        <Button
            android:id="@+id/btn_edit_profile"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Edit Profile"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue"/>

        <!-- Save Changes Button (Initially Hidden) -->
        <Button
            android:id="@+id/btn_save_changes"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Save Changes"
            android:visibility="gone"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue"/>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginTop="10dp"
            android:textColor="@color/black"
            android:backgroundTint="@color/cream"/>

    </LinearLayout>

</ScrollView>
